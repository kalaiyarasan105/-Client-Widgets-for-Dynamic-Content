{
  "name": "datumart-client-widgets",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "concurrently --names \"iframe,demo\" --prefix-colors \"cyan,magenta\" \"npm run dev --workspace=apps/iframe-widget\" \"npm run dev --workspace=apps/demo-host\"",
    "dev:iframe": "npm run dev --workspace=apps/iframe-widget",
    "dev:demo": "npm run dev --workspace=apps/demo-host",
    "dev": "concurrently \"npm run dev:iframe\" \"npm run dev:demo\"",
    "build:widgets": "npm run build --workspace=packages/react-widgets",
    "test": "npm run test --workspace=packages/react-widgets"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
